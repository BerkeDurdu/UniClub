# --- Core ---
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/uniclub_db
SECRET_KEY=change-me-please-32+chars-long-random-value
APP_ENV=development
DEBUG=true
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Seed users ---
SEED_MEMBER_EMAIL=member@uniclub.com
SEED_ADVISOR_EMAIL=advisor@uniclub.com
SEED_BOARD_EMAIL=board@uniclub.com
SEED_ADMIN_EMAIL=admin@uniclub.com
# Optional explicit passwords (recommended for stable demo)
# SEED_MEMBER_PASSWORD=Member#12345
# SEED_ADVISOR_PASSWORD=Advisor#12345
# SEED_BOARD_PASSWORD=Board#12345
# SEED_ADMIN_PASSWORD=Admin#12345

# --- OAuth providers (leave empty to hide a button) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000
OAUTH_FRONTEND_REDIRECT=http://localhost:5173/oauth/callback

# --- Email (Email OTP / 2FA). If unset, codes are printed to stdout. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@uniclub.local
SMTP_USE_TLS=true

# --- WebAuthn relying party ---
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=UniClub
WEBAUTHN_ORIGIN=http://localhost:5173
